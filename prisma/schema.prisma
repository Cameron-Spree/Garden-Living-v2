generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "darwin", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  name          String?
  password      String
  hardinessZone String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  plants        Plant[]
  exchangeItems ExchangeItem[]
  clinicPosts   ClinicPost[]
  rsvps         RSVP[]
  groupMessages GroupMessage[]
}

model Plant {
  id          String   @id @default(uuid())
  userId      String
  name        String
  species     String
  notes       String?
  lastWatered DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExchangeItem {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  location    String
  type        String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClinicPost {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  imageUrl    String?
  isResolved  Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Summit {
  id          String   @id @default(uuid())
  title       String
  description String
  expertName  String
  date        DateTime
  thumbnail   String?
  rsvps       RSVP[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RSVP {
  id        String   @id @default(uuid())
  userId    String
  summitId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summit    Summit   @relation(fields: [summitId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, summitId])
}

model Group {
  id          String         @id @default(uuid())
  name        String
  description String
  thumbnail   String?
  messages    GroupMessage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model GroupMessage {
  id        String   @id @default(uuid())
  userId    String
  groupId   String
  content   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
